# PaperTrail — Environment Configuration Template
# Copy this file to .env (both backend and frontend if running separately, or root if unified)
# DO NOT COMMIT REAL KEYS TO GIT

# ─── MongoDB Config ────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=papertrail

# ─── LLM Config (Groq & Fallbacks) ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_gemini_api_key_here
DEV_MODE=true


# ─── Search API Config (Tavily) ────────────────────────────────────────────
# Supports multiple comma-separated keys for automatic key rotation
TAVILY_KEYS=your_tavily_api_key_1,your_tavily_api_key_2

# ─── Auth Config (Supabase) ────────────────────────────────────────────────
SUPABASE_URL=https://your-supabase-project.supabase.co
# Backend uses this to validate JWT signatures/user info
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── CORS Configuration ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Frontend Environment Variables (React) ───────────────────────────────
# Place these in the frontend/.env or ensure they are set in the environment
# REACT_APP_BACKEND_URL=http://localhost:8000
# REACT_APP_SUPABASE_URL=https://your-supabase-project.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here
